prefix_rule(pattern=["rg"], decision="allow")
prefix_rule(pattern=["git", "status", "--short"], decision="allow")
prefix_rule(pattern=["sed"], decision="allow")
prefix_rule(pattern=["mv"], decision="allow")
prefix_rule(pattern=["gh", "--version"], decision="allow")
prefix_rule(pattern=["git", "switch", "-c"], decision="allow")
prefix_rule(pattern=["git", "commit"], decision="allow")
prefix_rule(pattern=["git", "push"], decision="allow")
prefix_rule(pattern=["gh", "pr", "create"], decision="allow")
prefix_rule(pattern=["gh", "auth", "status"], decision="allow")
prefix_rule(pattern=["ps"], decision="allow")
prefix_rule(pattern=["ls", "-la"], decision="allow")
prefix_rule(pattern=["gh", "pr", "view"], decision="allow")
prefix_rule(pattern=["npx", "tsc"], decision="allow")

# Common low-risk inspection and verification commands.
prefix_rule(pattern=["pwd"], decision="allow", justification="Print the current workspace path")
prefix_rule(pattern=["ls"], decision="allow", justification="List files for workspace inspection")
prefix_rule(pattern=["find"], decision="allow", justification="Inspect file trees without modifying files")
prefix_rule(pattern=["wc"], decision="allow", justification="Count lines/bytes for inspection")
prefix_rule(pattern=["date"], decision="allow", justification="Check the local system date/time")
prefix_rule(pattern=["git", "status"], decision="allow", justification="Inspect repository status")
prefix_rule(pattern=["git", "diff"], decision="allow", justification="Inspect unstaged or staged repository changes")
prefix_rule(pattern=["git", "log"], decision="allow", justification="Inspect commit history")
prefix_rule(pattern=["git", "show"], decision="allow", justification="Inspect commits and objects")
prefix_rule(pattern=["git", "branch"], decision="allow", justification="Inspect branches")
prefix_rule(pattern=["git", "rev-parse"], decision="allow", justification="Inspect git paths and refs")
prefix_rule(pattern=["git", "ls-files"], decision="allow", justification="Inspect tracked files")
prefix_rule(pattern=["npm", "test"], decision="allow", justification="Run project tests")
prefix_rule(pattern=["npm", "run", ["test", "build", "lint", "typecheck", "check"]], decision="allow", justification="Run common project verification scripts")

